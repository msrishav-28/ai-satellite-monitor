# ============================================================
#  ai-satellite-monitor — Backend Environment Configuration
#  Copy this to .env and fill in your values.
#  Lines beginning with # are comments.
# ============================================================

# --- Application -------------------------------------------------
DEBUG=true
HOST=0.0.0.0
PORT=8000
RUNTIME_ENV=local
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# CORS — add your frontend origin(s)
ALLOWED_HOSTS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Database ----------------------------------------------------
# SQLite (default, no setup needed for dev):
DATABASE_URL=sqlite:///./env_intel.db
# PostgreSQL + PostGIS (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/satellite_monitor
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Caching -----------------------------------------------------
ENABLE_CACHING=true
CACHE_TTL=300

# --- Google Earth Engine -----------------------------------------
# REQUIRED to unlock real satellite data (Sentinel-2 NDVI, MODIS LST,
# SRTM elevation, GPM precipitation, ESA WorldCover, SMAP soil moisture).
#
# Option A — Service Account JSON (preferred for production):
GEE_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
# GEE_CREDENTIALS_FILE=/path/to/your/service-account-key.json  # same as above

# Option B — User credentials (dev only, requires interactive browser auth):
# ALLOW_GEE_USER_AUTH=true

# Feature flag — set false once credentials are in place:
FORCE_MOCK_SATELLITE=true

# --- AI Narration (ai_analytics.py) ------------------------------
# Set OPENAI_API_KEY + FORCE_MOCK_AI=false to enable GPT-4o-mini narration.
# Without these, the service returns deterministic template insights.
OPENAI_API_KEY=
FORCE_MOCK_AI=true

# --- Weather (environmental.py) ----------------------------------
# https://openweathermap.org/api — free tier available
OPENWEATHER_API_KEY=
FORCE_MOCK_WEATHER=true

# --- Air Quality -------------------------------------------------
# https://aqicn.org/api/ — free token
WAQI_API_KEY=
FORCE_MOCK_AQI=true

# Premium AQI (optional):
IQAIR_API_KEY=
BREEZOMETER_API_KEY=
FORCE_MOCK_IQAIR=true
FORCE_MOCK_BREEZOMETER=true
FORCE_MOCK_ENHANCED_AQI=true
ENABLE_PREMIUM_AQI=false

# --- Mapping -----------------------------------------------------
# https://account.mapbox.com/ — free tier available (frontend only)
MAPBOX_ACCESS_TOKEN=

# https://developers.arcgis.com/ (optional)
ARCGIS_API_KEY=
ENABLE_ARCGIS=false

# --- Sentinel Hub (optional — faster imagery than GEE) -----------
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# --- ML Models ---------------------------------------------------
# Set false to enable physics-informed risk scoring.
# Full model training requires labeled hazard event data (see docs/).
FORCE_MOCK_MODELS=true
MODEL_DIR=models

# --- Background Tasks --------------------------------------------
ENABLE_BACKGROUND_TASKS=true
# Keep local refresh loops conservative; OpenWeather should not be polled more often than
# once per 10 minutes for the same location. Staging/production should use Celery workers.
BACKGROUND_TASK_INTERVAL=600

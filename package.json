{
  "name": "environmental-intelligence-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm --prefix space run dev",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "npm --prefix space run build",
    "start": "npm --prefix space run start",
    "start:backend": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "lint": "npm --prefix space run lint",
    "typecheck": "npm --prefix space run typecheck",
    "install:frontend": "npm --prefix space install --legacy-peer-deps",
    "test": "echo \"Project tests are split across backend and space\"",
    "test:backend": "cd backend && python -m pytest tests",
    "install:backend": "cd backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "prettier": "^3.2.5",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@turf/turf": "^7.2.0",
    "@types/d3-shape": "^3.1.7",
    "framer-motion": "^11.0.3",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0"
  }
}
